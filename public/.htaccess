# SPA fallback + caching for OVH mutualisé (Apache).
# Safe on GitHub Pages / nginx — they ignore this file.

Options -MultiViews
RewriteEngine On

# Don't rewrite real files or directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Client-side routing fallback
RewriteRule ^ index.html [L]

# Long cache for hashed build assets
<FilesMatch "\.(js|css|woff2|woff|ttf|png|jpe?g|webp|avif|svg|ico)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Never cache the entry HTML
<FilesMatch "^(index|404)\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# Gzip / Brotli when available
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
